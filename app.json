{
  "expo": {
    "name": "fypApp",
    "slug": "fypApp",
    "version": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/307f727f-acb1-4dbe-afd7-8ad789388109"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fypapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.umer913.tailorx"
    },
    "android": {
      "package": "com.umer913.tailorx",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f0f13"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f0f13",
          "dark": {
            "backgroundColor": "#0f0f13"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "307f727f-acb1-4dbe-afd7-8ad789388109"
      }
    }
  }
}
